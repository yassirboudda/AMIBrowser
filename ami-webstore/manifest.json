{
  "manifest_version": 3,
  "name": "AMI Web Store",
  "version": "1.0",
  "description": "Enables extension installation from Chrome Web Store in AMI Browser",
  "permissions": ["management"],
  "content_scripts": [
    {
      "matches": [
        "https://chromewebstore.google.com/*",
        "https://chrome.google.com/webstore/*"
      ],
      "js": ["webstore.js"],
      "css": ["webstore.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
